<file_content>package com.example.localbookmarks

import android.content.Intent
import android.os.Bundle
import android.widget.Toast
import androidx.activity.ComponentActivity
import androidx.lifecycle.lifecycleScope
import com.example.localbookmarks.data.Bookmark
import com.example.localbookmarks.data.BookmarkDatabase
import com.example.localbookmarks.data.BookmarkRepository
import kotlinx.coroutines.launch
import java.util.Date

class ShareReceiverActivity : ComponentActivity() {

    private val db by lazy { BookmarkDatabase.getDatabase(applicationContext) }
    private val repository by lazy { BookmarkRepository(db.bookmarkDao()) }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        if (intent?.action == Intent.ACTION_SEND && intent.type == "text/plain") {
            handleShareIntent(intent)
        } else {
            finish() // Not a share intent, close immediately.
        }
    }

    private fun handleShareIntent(intent: Intent) {
        val sharedText = intent.getStringExtra(Intent.EXTRA_TEXT)
        if (sharedText.isNullOrBlank()) {
            finish()
            return
        }

        // Simple URL extraction (first URL found)
        val urlRegex = "https?://[^\\s]+".toRegex()
        val matchResult = urlRegex.find(sharedText)
        val url = matchResult?.value

        if (url != null) {
            lifecycleScope.launch {
                repository.insert(Bookmark(url = url, title = url, timestamp = Date()))
                Toast.makeText(applicationContext, "Bookmark added", Toast.LENGTH_SHORT).show()
            }
        } else {
            Toast.makeText(applicationContext, "No URL found", Toast.LENGTH_SHORT).show()
        }

        // Finish the activity after initiating the save
        finish()
    }
}
</file_content>
